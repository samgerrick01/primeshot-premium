# Copy this file to .env.local and fill in the values
# .env.local is in .gitignore so it won't be committed

# Your Brevo (Sendinblue) API Key
BREVO_API_KEY=your_brevo_api_key_here

# Supabase Project URL (same as VITE_SUPABASE_URL in .env)
SUPABASE_URL=https://rxxkbozsqgmirketwmvb.supabase.co

# Supabase Service Role Key (get this from Supabase Dashboard > Settings > API)
# IMPORTANT: This is a secret key with admin privileges. Never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
